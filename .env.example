PORT=3000
NODE_ENV=development
\n+# CORS for frontends
CORS_ORIGINS=http://localhost:5173

# Embeddings
EMBEDDING_PROVIDER=openai # or 'ollama', 'azure-openai', etc.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_ALT_MODEL=text-embedding-3-large
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_BASE_MS=200
# Optional pacing between successful batches in eval context (ms)
EVAL_EMBED_SLEEP_MS=0
# Enforce minimum interval between any embedding API calls (ms)
EMBEDDING_GLOBAL_MIN_INTERVAL_MS=0
# Embedding cache path (JSON map); keep out of VCS
EMBEDDING_CACHE_PATH=.cache/embeddings.json

# Azure OpenAI (optional, set EMBEDDING_PROVIDER=azure-openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_EMBEDDING_DEPLOYMENT=

# Dimension eval flags (src/eval/compare_dims.ts uses these)
# Set one or both to true to restrict evaluation scope on reruns.
DIM_EVAL_ONLY_BASE=false
DIM_EVAL_ONLY_ALT=false

# Vector DB
VECTOR_DB=qdrant # or 'pinecone', 'memory'
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=maxwell-brain
PINECONE_INDEX_HOST= # e.g., my-index-xxxx.svc.us-east1-aws.pinecone.io

# Collection/Index
VECTOR_COLLECTION=maxwell_knowledge

# NOTE: The dimension evaluation script forces an in-memory index for isolation;
# changing VECTOR_DB here won't affect compare_dims.ts runs.

# Retrieval weight tuning (alpha=vector, beta=lexical, gamma=tags/preferences)
RETRIEVE_ALPHA=0.7
RETRIEVE_BETA=0.2
RETRIEVE_GAMMA=0.1
RETRIEVAL_ENABLED=true

# Reranker (optional)
RERANK_ENABLED=false
RERANK_LAMBDA=0.5
RERANK_TOPN=25

# Deduplication
DEDUP_HASHES=32
DEDUP_JACCARD_THRESHOLD=0.85

# Auth & Rate Limiting
# NOTE: Set strong random values; these are placeholders only.
ADMIN_API_KEY=changeme_admin_key
API_KEYS=changeme_client_key_a,changeme_client_key_b
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=20

# (Dynamic config changes are persisted in config.snapshots.json; keep ADMIN_API_KEY secret.)

# Voice (Hugging Face Inference API)
HUGGINGFACE_API_TOKEN=
HF_TTS_MODEL=  # e.g., your-org/your-voice-tts
HF_TTS_PARAMETERS= # optional JSON string, e.g. {"speaker_wav":"/voices/john_ref.wav"}
HF_TTS_ENDPOINT=

# Conversation persistence
CONVERSATION_STORE_PATH=.cache/conversations.json

# Persona & content
AUTO_INGEST_DIR=./data/transcripts
PERSONA_PATH=./data/persona/john_persona_curated.md
PERSONA_SNIPPETS_ENABLED=true

# Live context
DATETIME_ENABLED=true
WEATHER_ENABLED=false
WEATHER_CACHE_MS=900000
